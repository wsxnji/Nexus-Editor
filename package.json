{
  "name": "nexus-editor",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm --filter @nexus/core build && pnpm --filter @nexus/react build && pnpm --filter @nexus/vue build && pnpm --filter @nexus/preset-gfm build && pnpm --filter @nexus/plugin-slash build && pnpm --filter @nexus/plugin-history build && pnpm --filter @nexus/plugin-search build",
    "test": "vitest run",
    "dev:electron-demo": "pnpm --filter @nexus/electron-demo dev",
    "build:electron-demo": "pnpm --filter @nexus/electron-demo build"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vue": "^3.5.22",
    "vitest": "^2.1.9"
  }
}
